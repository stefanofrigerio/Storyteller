# Database Configuration
# Copy this file to .env in the project root and update with your values

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/storyteller

# Alternative formats:
# DATABASE_URL=postgresql://storyteller_user:your_password@localhost:5432/storyteller
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/storyteller?sslmode=require

# For production, consider:
# - Using strong passwords
# - Enabling SSL/TLS (sslmode=require)
# - Using connection pooling parameters
# - Setting up read replicas if needed
